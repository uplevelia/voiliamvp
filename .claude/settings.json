{
  "allowedCommands": [
    "docker:*",
    "docker-compose:*",
    "ffmpeg:*",
    "ffprobe:*",
    "npm:*",
    "python:*",
    "python3:*",
    "pip:*",
    "pip3:*",
    "pytest:*",
    "psql:*",
    "redis-cli:*",
    "git:*",
    "curl:*",
    "wget:*",
    "celery:*",
    "alembic:*",
    "rm:/tmp/*",
    "rm:/root/uplevelia/projects/voilia/tmp/*"
  ],
  "blockedCommands": [
    "sudo:*",
    "rm:-rf /",
    "rm:-rf ~",
    "nvidia-smi:*",
    "systemctl:*",
    "reboot",
    "shutdown"
  ],
  "autoApprove": {
    "read": true,
    "write": true,
    "edit": true
  }
}
