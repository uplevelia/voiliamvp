# VOILIA Environment Variables - SECURE CONFIGURATION
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env file to version control

# Database Configuration
DATABASE_URL=postgresql://voilia:YOUR_SECURE_PASSWORD@postgres:5432/voilia
POSTGRES_DB=voilia
POSTGRES_USER=voilia
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# Redis Configuration
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# AWS Credentials (for S3 storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET=voilia-renders

# Application Settings
ENVIRONMENT=development
SECRET_KEY=your_secret_key_here_min_32_characters
DEBUG=false

# Docker User ID (optional, defaults to 1000)
UID=1000
GID=1000

# Security Notes:
# 1. Use strong passwords (min 16 characters, mixed case, numbers, symbols)
# 2. Never reuse passwords across services
# 3. Rotate credentials regularly
# 4. Use AWS IAM roles in production instead of access keys when possible
